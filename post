Here's how I'd architect this in Godot:

CLI Argument Parsing
In your main scene's _ready():
gdscriptfunc _ready():
    var args = OS.get_cmdline_args()
    var time = "golden_hour"  # default
    var weather = "clear"     # default

    for i in args.size():
        if args[i] == "--time" and i + 1 < args.size():
            time = args[i + 1]
        if args[i] == "--weather" and i + 1 < args.size():
            weather = args[i + 1]

    SimulationManager.apply_time(time)
    SimulationManager.apply_weather(weather)
Launch examples:
bash./central_park --time night --weather snow
./central_park --time dawn --weather fog
./central_park --weather lens  # defaults to golden hour

SimulationManager (Autoload Singleton)
This drives everything — lighting, environment, particles, camera, post-processing:
gdscript# SimulationManager.gd
extends Node

@onready var env: WorldEnvironment = $WorldEnvironment
@onready var sun: DirectionalLight3D = $Sun
@onready var camera: Camera3D = $Camera3D

func apply_time(preset: String):
    match preset:
        "dawn":       _set_dawn()
        "morning":    _set_morning()
        "noon":       _set_noon()
        "golden_hour":_set_golden_hour()
        "dusk":       _set_dusk()
        "night":      _set_night()
        _:            _set_golden_hour()

func apply_weather(preset: String):
    match preset:
        "rain":   _set_rain()
        "snow":   _set_snow()
        "fog":    _set_fog()
        "lens":   _set_lens()
        "clear":  _set_clear()
        _:        _set_clear()

